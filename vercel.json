{
  "version": 2,
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @gamedao/evm run build && pnpm --filter @gamedao/frontend exec next build",
  "outputDirectory": "packages/frontend/.next",
  "regions": ["iad1"],
  "functions": {
    "packages/frontend/src/app/api/**/*.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  }
}
