# GameDAO Protocol Environment Configuration
# Copy this file to .env.local and update with your values.
#
# Contract addresses, ABIs, and chain metadata are NOT configured here.
# They live in the @gamedao/evm package (packages/shared/src/deployments/
# and packages/shared/src/chains.ts) and are consumed by frontend, subgraph,
# and Hardhat scripts via getConfig(chainId).

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Default chainId the frontend connects to.
# - 31337 = Hardhat (local Docker stack — `make docker-deploy-all`)
# - 80002 = Polygon Amoy (public-beta testnet)
# - 137   = Polygon mainnet
# Frontier (chainId 42) is opt-in via `pnpm run deploy:frontier` /
# `make deploy-local-frontier` and shares the localhost manifest.
NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337

# RPC URLs (used by Hardhat for deploys and the frontend for non-injected
# read fallbacks). Defaults from chains.ts work for casual local dev; set
# real RPC endpoints (Alchemy/Infura/etc) for sustained beta/prod usage.
POLYGON_AMOY_URL=https://rpc-amoy.polygon.technology
POLYGON_URL=https://polygon-rpc.com

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Private key used by Hardhat for testnet/mainnet deploys.
# DO NOT commit. Leave empty when only deploying locally — the localhost
# network uses the standard Hardhat default test accounts.
PRIVATE_KEY=

# Initial protocol admin (sudo). Bootstraps Registry roles in deploy.ts.
PROTOCOL_SUDO=0xf0FE780c76ce610FC8DF330971b99Ba6f4429001

# Polygonscan API key — used for `make verify` on amoy + polygon.
POLYGONSCAN_API_KEY=

# The Graph deploy key — used to publish the subgraph to Studio for
# amoy/polygon (not needed for local graph-node).
GRAPH_DEPLOY_KEY=

# =============================================================================
# AUTH / WALLETS (PRIVY)
# =============================================================================

# Privy app id — created in the Privy Dashboard (https://dashboard.privy.io).
# This is a public client identifier; do not commit a real value here, the
# operator injects it at deploy time. The matching origin (e.g.
# http://localhost:3333 for dev, https://app.gamedao.co for prod) MUST be
# added to Dashboard > Settings > Domains, otherwise login fails with
# `invalid_origin`.
NEXT_PUBLIC_PRIVY_APP_ID=

# =============================================================================
# IPFS CONFIGURATION
# =============================================================================

# Mode: local (Kubo via docker) or pinata
NEXT_PUBLIC_IPFS_MODE=local

# Primary gateways for reads (trailing / required). If not set, defaults to:
# - local private: http://localhost:8080/ipfs/
# - public: https://gateway.pinata.cloud/ipfs/
NEXT_PUBLIC_IPFS_PUBLIC_GATEWAY=
NEXT_PUBLIC_IPFS_PRIVATE_GATEWAY=

# Backward-compatible vars (optional):
# NEXT_PUBLIC_IPFS_GATEWAY (public), NEXT_PUBLIC_IPFS_LOCAL_GATEWAY (private)
NEXT_PUBLIC_IPFS_GATEWAY=

# Local Kubo API base (used when NEXT_PUBLIC_IPFS_MODE=local)
# Default: http://localhost:5001/api/v0
NEXT_PUBLIC_IPFS_API=

# Local Kubo gateway override (used when NEXT_PUBLIC_IPFS_MODE=local)
# Default: http://localhost:8080/ipfs/
NEXT_PUBLIC_IPFS_LOCAL_GATEWAY=

# Pinata credentials (used when NEXT_PUBLIC_IPFS_MODE=pinata)
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_PINATA_SECRET_KEY=

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Gas reporting
REPORT_GAS=false

# Environment
NODE_ENV=development

